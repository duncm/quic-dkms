# Files that may exist in the working tree but should never end up in
# the .debian.tar.xz that dpkg-source generates.
#
# extend-diff-ignore is a Perl regex matched against each path; we use
# it to strip Git metadata that has no place in a Debian source package.
extend-diff-ignore = "(^|/)(\.git|\.gitignore|\.gitmodules)$"

# Patches in debian/patches/ are applied to upstream/modules/* by
# dpkg-source's quilt machinery before debian/rules runs.  Tell
# dpkg-source to UNapply them in --after-build so that:
#   * a fresh `dpkg-buildpackage` from git leaves the upstream/
#     submodule's working tree clean (no spurious dirty files), and
#   * a `dpkg-source -x` of our .dsc followed by a build doesn't
#     accumulate "already applied" warnings on a second build.
unapply-patches
